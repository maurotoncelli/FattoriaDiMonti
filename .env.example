# ============================================================
# Fattoria di Monti — Variabili d'Ambiente
# ============================================================
# Copia questo file in .env.local per lo sviluppo locale.
# NON committare mai .env.local su GitHub.
#
# Su Netlify: vai in Site > Environment variables e aggiungi
# le variabili di produzione direttamente nella dashboard.
# ============================================================


# ── Google Analytics 4 ───────────────────────────────────────
# Measurement ID del tuo GA4 property (formato: G-XXXXXXXXXX)
# Trovalo su: analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Forza il caricamento di GA anche senza cookie consent
# (solo per testing locale — non usare in produzione)
NEXT_PUBLIC_GA_FORCE_DEV=false


# ── URL del sito ─────────────────────────────────────────────
# URL pubblico di produzione (senza slash finale)
NEXT_PUBLIC_SITE_URL=https://www.fattoriadimonti.it


# ── API Contact Form ─────────────────────────────────────────
# Se usi un servizio email per il form concierge (es. Resend, Sendgrid)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL_TO=info@fattoriadimonti.it
# CONTACT_EMAIL_FROM=noreply@fattoriadimonti.it


# ── Sanity CMS (futuro) ──────────────────────────────────────
# NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxx
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01


# ── Cloudinary / CDN media (futuro) ──────────────────────────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=fattoriadimonti
